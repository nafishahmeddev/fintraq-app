{
  "expo": {
    "name": "Fintraq",
    "slug": "luno",
    "version": "1.1.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "luno",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "newArchEnabled": true,
    "notification": {
      "icon": "./assets/images/android-icon-monochrome.png",
      "color": "#205FA8",
      "iosDisplayInForeground": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "me.nafish.luno",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon/foreground.png",
        "backgroundImage": "./assets/images/adaptive-icon/background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "me.nafish.luno",
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 224,
          "resizeMode": "contain",
          "backgroundColor": "#080D16",
          "dark": {
            "backgroundColor": "#080D16"
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-localization",
      "expo-iap",
      "expo-notifications",
      "expo-system-ui",
      "expo-secure-store",
      "./plugins/with-fingerprint-not-required"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a7e2214b-0152-4a29-be8b-06ead99609b4"
      }
    },
    "owner": "nafish.ahmed.dev"
  }
}
